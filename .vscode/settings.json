{
  "latex-workshop.latex.build.forceRecipeUsage": false,
  "latex-workshop.synctex.afterBuild.enabled": true,
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
  "latex-workshop.latex.outDir": "./out",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.watch.usePolling": true,
  "latex-workshop.latex.watch.pdf.delay": 1000,
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.search.rootFiles.exclude": [
    "**/out/**"
  ],
  "latex-workshop.latex.rootFile.doNotPrompt": true,
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk (pdfLaTeX)",
      "command": "C:\\Users\\pauline.guesdon\\AppData\\Local\\Programs\\MiKTeX\\miktex\\bin\\x64\\latexmk.exe",
      "env": {
        "PATH": "C:\\Users\\pauline.guesdon\\AppData\\Local\\Programs\\MiKTeX\\miktex\\bin\\x64;${env:PATH}"
      },
      "args": [
        "-g",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (pdfLaTeX)",
      "tools": [
        "latexmk (pdfLaTeX)"
      ]
    }
  ]
}
