@Misc{MajoranaNotes,
  Note         = {In the stellar representation, a $SU(2)$ rotation $\mathrm{exp(i \theta \vec \alpha . \vec F)}$ corresponds to a complicated periodic motion of stars with a $2 \pi$ periodicity in $\theta$ (meaning that each star comes back to its original position after a full $2 \pi$ rotation). In contrast, a coherent oscillation between two chosen spin states, driven by $\sigma_{m_F,m_F'} \otimes \mathbb{1} $, can also correspond to an exchange between two Majorana stars, or to more complex permutations.},
}

