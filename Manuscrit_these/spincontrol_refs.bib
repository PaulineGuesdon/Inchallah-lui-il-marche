@Article{Deng2021,
  author   = {Deng, Tian-Shu and Pan, Lei},
  journal  = {Physical Review B},
  title    = {Fate of symmetry protected coherence in open quantum system},
  year     = {2021},
  month    = sep,
  note     = {Publisher: American Physical Society},
  number   = {9},
  pages    = {094306},
  volume   = {104},
  abstract = {We investigate the fate of coherence in the dynamical evolution of symmetry protected quantum systems. Under the formalism of system plus bath for open quantum systems, antiunitary symmetries exhibit significant differences from the unitary ones in protecting initial coherence. Specifically, taking advantage of the Lindblad master equation, we find that a pure state in the symmetry protected degenerate subspace will be decoherent even though both the system Hamiltonian and system-environment interaction respect the same antiunitary symmetry. In contrast, the coherence will persist when the protecting symmetry is unitary. We provide an elaborate classification table to illustrate what kinds of symmetry combinations are able to preserve the coherence of the initial state, which is confirmed in several concrete models of single spin-3/2 systems. It can also be applied to the Haldane phase in interacting topological systems. Our results could be helpful in exploring possible experimental realization of stable time-reversal symmetric topological states.},
  doi      = {10.1103/PhysRevB.104.094306},
  file     = {APS Snapshot:C\:\\Users\\GQD\\Zotero\\storage\\LRA5ACQL\\PhysRevB.104.html:text/html;Version soumise:C\:\\Users\\GQD\\Zotero\\storage\\BMBYTJ2E\\Deng et Pan - 2021 - Fate of symmetry protected coherence in open quant.pdf:application/pdf},
  url      = {https://link.aps.org/doi/10.1103/PhysRevB.104.094306},
  urldate  = {2022-10-28},
}

