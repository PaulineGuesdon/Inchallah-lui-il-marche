@Article{McFerran2010,
  Title                    = {Fractional frequency instability in the $10^{-14}$ range with a thermal beam optical frequency reference},
  Author                   = {John J. McFerran and Andre N. Luiten},
  Journal                  = {J. Opt. Soc. Am. B},
  Year                     = {2010},

  Month                    = {Feb},
  Number                   = {2},
  Pages                    = {277--285},
  Volume                   = {27},

  Abstract                 = {We demonstrate a means of increasing the signal-to-noise ratio in a Ramsey-Bord\'{e} interferometer with spatially separated oscillatory fields on a thermal atomic beam. The S01?P13 intercombination line in neutral Ca40 is used as a frequency discriminator, with an extended cavity diode laser at 423 nm probing the ground state population after a Ramsey-Bord\'{e} sequence of 657 nm light-field interactions with the atoms. Evaluation of the instability of the Ca frequency reference is carried out by comparison with (i) a hydrogen-maser and (ii) a cryogenic sapphire oscillator. In the latter case the Ca reference exhibits a square-root $\Lambda$ variance of 9.2{\texttimes}10{\textminus}14 at 1 s and 2.0{\texttimes}10{\textminus}14 at 64 s. This is an order-of-magnitude improvement for optical beam frequency references, to our knowledge. The shot noise of the readout fluorescence produces a limiting square-root $\Lambda$ variance of 7{\texttimes}10{\textminus}14/{\textsurd}$\tau$, highlighting the potential for improvement. This work demonstrates the feasibility of a portable frequency reference in the optical domain with 10{\textminus}14 range frequency instability.},
  Doi                      = {10.1364/JOSAB.27.000277},
  Keywords                 = {Metrological instrumentation; Optical standards and testing; Spectroscopy, fluorescence and luminescence; Atom optics ; Atomic fluorescence; Electric fields; Laser beams; Laser sources; Magnetic fields; Phase measurement},
  Publisher                = {OSA},
  Url                      = {http://josab.osa.org/abstract.cfm?URI=josab-27-2-277}
}

