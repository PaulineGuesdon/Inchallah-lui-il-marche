@Article{Bridge2016,
  Title                    = {Tunable cw UV laser with \&\#x0003C;35 kHz absolute frequency instability for precision spectroscopy of Sr Rydberg states},
  Author                   = {Elizabeth M. Bridge and Niamh C. Keegan and Alistair D. Bounds and Danielle Boddy and Daniel P. Sadler and Matthew P. A. Jones},
  Journal                  = {Opt. Express},
  Year                     = {2016},

  Month                    = {Feb},
  Number                   = {3},
  Pages                    = {2281--2292},
  Volume                   = {24},

  Abstract                 = {We present a solid-state laser system that generates over 200 mW of continuous-wave, narrowband light, tunable from 316.3 nm \&\#x02013; 317.7 nm and 318.0 nm \&\#x02013; 319.3 nm. The laser is based on commercially available fiber amplifiers and optical frequency doubling technology, along with sum frequency generation in a periodically poled stoichiometric lithium tantalate crystal. The laser frequency is stabilized to an atomic-referenced high finesse optical transfer cavity. Using a GPS-referenced optical frequency comb we measure a long term frequency instability of \&\#x0003C; 35 kHz for timescales between 10\&\#x02212;3 s and 103 s. As an application we perform spectroscopy of Sr Rydberg states from n $=$ 37 \&\#x02013; 81, demonstrating mode-hop-free scans of 24 GHz. In a cold atomic sample we measure Doppler-limited linewidths of 350 kHz.},
  Doi                      = {10.1364/OE.24.002281},
  Keywords                 = {Rydberg states; Lasers and laser optics; Lasers, tunable; Lasers, ultraviolet},
  Publisher                = {OSA},
  Url                      = {http://www.opticsexpress.org/abstract.cfm?URI=oe-24-3-2281}
}

