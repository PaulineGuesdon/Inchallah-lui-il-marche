@Article{Rosso2021,
  author     = {Rosso, Lorenzo and Rossini, Davide and Biella, Alberto and Mazza, Leonardo},
  journal    = {Physical Review A},
  title      = {One-dimensional spin-1/2 fermionic gases with two-body losses: {Weak} dissipation and spin conservation},
  year       = {2021},
  month      = nov,
  note       = {Publisher: American Physical Society},
  number     = {5},
  pages      = {053305},
  volume     = {104},
  abstract   = {We present a theoretical analysis of the dynamics of a one-dimensional spin-1/2 fermionic gas subject to weak two-body losses. Our approach highlights the crucial role played by spin conservation in the determination of the full time evolution. We focus in particular on the dynamics of a gas that is initially prepared in a Dicke state with a fully symmetric spin wave function, in a band insulator, or in a Mott insulator. In the latter case, we investigate the emergence of a steady symmetry-resolved purification of the gas. Our results could help with the modelization and understanding of recent experiments with alkaline-earth(-like) gases like ytterbium and fermionic molecules.},
  doi        = {10.1103/PhysRevA.104.053305},
  file       = {APS Snapshot:C\:\\Users\\GQD\\Zotero\\storage\\QVB3JGWX\\PhysRevA.104.html:text/html;Full Text PDF:C\:\\Users\\GQD\\Zotero\\storage\\F9WSJZTS\\Rosso et al. - 2021 - One-dimensional spin-12 fermionic gases with two-.pdf:application/pdf},
  shorttitle = {One-dimensional spin-1/2 fermionic gases with two-body losses},
  url        = {https://link.aps.org/doi/10.1103/PhysRevA.104.053305},
  urldate    = {2022-10-20},
}

@Article{Rosso2022,
  author   = {Rosso, Lorenzo and Mazza, Leonardo and Biella, Alberto},
  journal  = {Physical Review A},
  title    = {Eightfold way to dark states in {SU}(3) cold gases with two-body losses},
  year     = {2022},
  issn     = {2469-9926, 2469-9934},
  month    = may,
  note     = {arXiv:2201.12889 [cond-mat, physics:quant-ph]},
  number   = {5},
  pages    = {L051302},
  volume   = {105},
  abstract = {We study the quantum dynamics of a one-dimensional SU(3)-symmetric system of cold atoms in the presence of two-body losses. We exploit the representation theory of SU(3), the so-called eightfold way, as a scheme to organize the dark states of the dissipative dynamics in terms of generalized Dicke states and show how they are dynamically approached, both in the weakly- and and strongly-interacting and dissipative regimes. Our results are relevant for a wide class of alkaline-earth(-like) gases experiments, paving the way to the dissipative preparation and exploitation of generalized Dicke states.},
  annote   = {Comment: 17 pages (5 main text + 12 Sup. Mat.), 7 figures},
  doi      = {10.1103/PhysRevA.105.L051302},
  file     = {arXiv Fulltext PDF:C\:\\Users\\GQD\\Zotero\\storage\\TZEZ5EGE\\Rosso et al. - 2022 - Eightfold way to dark states in SU(3) cold gases w.pdf:application/pdf;arXiv.org Snapshot:C\:\\Users\\GQD\\Zotero\\storage\\8ZLSPUJN\\2201.html:text/html},
  keywords = {Condensed Matter - Quantum Gases, Quantum Physics},
  url      = {http://arxiv.org/abs/2201.12889},
  urldate  = {2022-10-20},
}

@Article{FossFeig2012,
  author   = {Foss-Feig, Michael and Daley, Andrew J. and Thompson, James K. and Rey, Ana Maria},
  journal  = {Physical Review Letters},
  title    = {Steady-{State} {Many}-{Body} {Entanglement} of {Hot} {Reactive} {Fermions}},
  year     = {2012},
  month    = dec,
  note     = {Publisher: American Physical Society},
  number   = {23},
  pages    = {230501},
  volume   = {109},
  abstract = {Entanglement is typically created via systematic intervention in the time evolution of an initially unentangled state, which can be achieved by coherent control, carefully tailored nondemolition measurements, or dissipation in the presence of properly engineered reservoirs. In this Letter we show that two-component Fermi gases at ∼μK temperatures naturally evolve, in the presence of reactive two-body collisions, into states with highly entangled (Dicke-type) spin wave functions. The entanglement is a steady-state property that emerges-without any intervention-from uncorrelated initial states, and could be used to improve the accuracy of spectroscopy in experiments with fermionic alkaline earth atoms or fermionic ground state molecules.},
  doi      = {10.1103/PhysRevLett.109.230501},
  file     = {APS Snapshot:C\:\\Users\\GQD\\Zotero\\storage\\WSZXBE37\\PhysRevLett.109.html:text/html;Full Text PDF:C\:\\Users\\GQD\\Zotero\\storage\\DVBUIRJV\\Foss-Feig et al. - 2012 - Steady-State Many-Body Entanglement of Hot Reactiv.pdf:application/pdf},
  url      = {https://link.aps.org/doi/10.1103/PhysRevLett.109.230501},
  urldate  = {2022-10-20},
}

@Article{Pezze2018,
  author   = {Pezzè, Luca and Smerzi, Augusto and Oberthaler, Markus K. and Schmied, Roman and Treutlein, Philipp},
  journal  = {Reviews of Modern Physics},
  title    = {Quantum metrology with nonclassical states of atomic ensembles},
  year     = {2018},
  month    = sep,
  note     = {Publisher: American Physical Society},
  number   = {3},
  pages    = {035005},
  volume   = {90},
  abstract = {Quantum technologies exploit entanglement to revolutionize computing, measurements, and communications. This has stimulated the research in different areas of physics to engineer and manipulate fragile many-particle entangled states. Progress has been particularly rapid for atoms. Thanks to the large and tunable nonlinearities and the well-developed techniques for trapping, controlling, and counting, many groundbreaking experiments have demonstrated the generation of entangled states of trapped ions, cold, and ultracold gases of neutral atoms. Moreover, atoms can strongly couple to external forces and fields, which makes them ideal for ultraprecise sensing and time keeping. All these factors call for generating nonclassical atomic states designed for phase estimation in atomic clocks and atom interferometers, exploiting many-body entanglement to increase the sensitivity of precision measurements. The goal of this article is to review and illustrate the theory and the experiments with atomic ensembles that have demonstrated many-particle entanglement and quantum-enhanced metrology.},
  doi      = {10.1103/RevModPhys.90.035005},
  file     = {APS Snapshot:C\:\\Users\\GQD\\Zotero\\storage\\2QAGKFJZ\\RevModPhys.90.html:text/html;Full Text PDF:C\:\\Users\\GQD\\Zotero\\storage\\W2967WNV\\Pezzè et al. - 2018 - Quantum metrology with nonclassical states of atom.pdf:application/pdf},
  url      = {https://link.aps.org/doi/10.1103/RevModPhys.90.035005},
  urldate  = {2022-10-21},
}

@Article{Zelevinsky2007,
  author   = {Zelevinsky, T. and Boyd, M. M. and Ludlow, A. D. and Foreman, S. M. and Blatt, S. and Ido, T. and Ye, J.},
  journal  = {Hyperfine Interactions},
  title    = {Optical clock and ultracold collisions with trapped strontium atoms},
  year     = {2007},
  issn     = {1572-9540},
  month    = jan,
  number   = {1},
  pages    = {55--64},
  volume   = {174},
  abstract = {With microkelvin neutral strontium atoms confined in an optical lattice, we have achieved a fractional resolution of better than 5×10–15 on the 1S0–3P0 doubly forbidden 87Sr clock transition at 698 nm. Measurements of the clock line shifts as a function of experimental parameters indicate that the fractional uncertainties due to systematic shifts could be reduced below 10–15. The ultrahigh spectral resolution permitted resolving the nuclear spin states of the clock transition at small magnetic fields, leading to measurements of the 3P0 magnetic moment and metastable lifetime. In addition, photoassociation spectroscopy was performed on the narrow 1S0–3P1 transition of 88Sr, revealing the least-bound state, and showing promise for efficient optical tuning of the ground state scattering length and production of cold molecules.},
  doi      = {10.1007/s10751-007-9564-x},
  file     = {Full Text PDF:C\:\\Users\\GQD\\Zotero\\storage\\QEF233UH\\Zelevinsky et al. - 2007 - Optical clock and ultracold collisions with trappe.pdf:application/pdf},
  keywords = {Optical clock, Optical lattice, Photoassociation},
  language = {en},
  url      = {https://doi.org/10.1007/s10751-007-9564-x},
  urldate  = {2022-10-21},
}

@Article{Nagel2005,
  author   = {Nagel, S. B. and Mickelson, P. G. and Saenz, A. D. and Martinez, Y. N. and Chen, Y. C. and Killian, T. C. and Pellegrini, P. and Côté, R.},
  journal  = {Physical Review Letters},
  title    = {Photoassociative {Spectroscopy} at {Long} {Range} in {Ultracold} {Strontium}},
  year     = {2005},
  month    = mar,
  note     = {Publisher: American Physical Society},
  number   = {8},
  pages    = {083004},
  volume   = {94},
  abstract = {We report photoassociative spectroscopy of 88Sr2 in a magneto-optical trap operating on the 1S0→3P1 intercombination line at 689 nm. Photoassociative transitions are driven with a laser red detuned by 600–2400 MHz from the 1S0→1P1 atomic resonance at 461 nm. Photoassociation takes place at extremely large internuclear separation, and the photoassociative spectrum is strongly affected by relativistic retardation. A fit of the transition frequencies determines the 1P1 atomic lifetime (τ=5.22±0.03 ns) and resolves a discrepancy between experiment and recent theoretical calculations.},
  doi      = {10.1103/PhysRevLett.94.083004},
  file     = {APS Snapshot:C\:\\Users\\GQD\\Zotero\\storage\\KUHFSAQK\\PhysRevLett.94.html:text/html;Full Text PDF:C\:\\Users\\GQD\\Zotero\\storage\\753KJC3Z\\Nagel et al. - 2005 - Photoassociative Spectroscopy at Long Range in Ult.pdf:application/pdf},
