  month    = may,
  note     = {Publisher: American Physical Society},
  number   = {19},
  pages    = {190401},
  volume   = {92},
  abstract = {We investigate the correlation properties of a one-dimensional interacting Bose gas by loading a magnetically trapped Bose-Einstein condensate (BEC) into a deep two-dimensional optical lattice. We measure the three-body recombination rate for both the BEC in the magnetic trap and the BEC loaded into the optical lattice. The recombination rate coefficient is a factor of 7 smaller in the lattice, which we interpret as a reduction in the local three-body correlation function in the 1D case. This is a signature of correlation intermediate between that of the uncorrelated, phase coherent, 1D, mean-field regime and the strongly correlated Tonks-Girardeau regime.},
