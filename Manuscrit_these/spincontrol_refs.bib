  Author                   = {Remington, Bruce A. and Arnett, David and Paul , R. and Drake and Takabe, Hideaki},
  Journal                  = {Science},
  Year                     = {1999},
  Number                   = {5419},
  Pages                    = {1488-1493},
  Volume                   = {284},

  Abstract                 = {Astrophysical research has traditionally been divided into observations and theoretical modeling or a combination of both. A component sometimes missing has been the ability to quantitatively test the observations and models in an experimental setting where the initial and final states are well characterized. Intense lasers are now being used to recreate aspects of astrophysical phenomena in the laboratory, allowing the creation of experimental test beds where observations and models can be quantitatively compared with laboratory data. Experiments are under development at intense laser facilities to test and refine our understanding of phenomena such as supernovae, supernova remnants, gamma-ray bursts, and giant planets.},
  Doi                      = {10.1126/science.284.5419.1488},
